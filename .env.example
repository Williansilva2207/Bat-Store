# App / Uvicorn
APP_HOST=0.0.0.0
APP_PORT=8000

# Host Port Mappings
AUTH_HOST_PORT=8001
CATALOG_HOST_PORT=8002
ORDER_HOST_PORT=8003
PAYMENT_HOST_PORT=8004
NOTIFICATION_HOST_PORT=8005
GRAFANA_HOST_PORT=3000
PROMETHEUS_HOST_PORT=9090
REDIS_HOST_PORT=6379
JAEGER_HOST_PORT=16686


# Auth / JWT
JWT_SECRET=change-me-to-a-secure-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Initial auth users
INITIAL_ADMIN_USERNAME=batman
INITIAL_ADMIN_PASSWORD=batman123
INITIAL_USER_USERNAME=robin
INITIAL_USER_PASSWORD=robin123
INITIAL_SUPPORT_USERNAME=alfred
INITIAL_SUPPORT_PASSWORD=alfred123

# Redis / Broker
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_NAME=fila_pedidos
REDIS_BLOCK_TIMEOUT=5
REDIS_RECONNECT_INTERVAL=5

# Service URLs (internal Docker network)
AUTH_SERVICE_URL=http://bat-auth-service:8000
CATALOG_SERVICE_URL=http://bat-catalog-service:8000
PAYMENT_SERVICE_URL=http://bat-payment-service:8000
ORDER_SERVICE_URL=http://bat-order-service:8000
NOTIFICATION_SERVICE_URL=http://bat-notification-service:8000

# Timeouts
REQUEST_TIMEOUT=3
CATALOG_REQUEST_TIMEOUT=3.0

# SQLite databases
AUTH_DB_FILE=auth.db
CATALOG_DB_FILE=catalog.db
ORDERS_DB_FILE=orders.db
PAYMENTS_DB_FILE=payments.db
NOTIFICATIONS_DB_FILE=notifications.db

# OpenTelemetry / Jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=bat-store
