# App / Uvicorn
APP_HOST=0.0.0.0
APP_PORT=8000

# Docker host ports
CATALOG_HOST_PORT=8000
ORDER_HOST_PORT=8001
PAYMENT_HOST_PORT=8002
NOTIFICATION_HOST_PORT=8003
AUTH_HOST_PORT=8004
REDIS_HOST_PORT=6379

# Auth / JWT
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Initial auth users
INITIAL_ADMIN_USERNAME=batman
INITIAL_ADMIN_PASSWORD=change-me
INITIAL_USER_USERNAME=robin
INITIAL_USER_PASSWORD=change-me
INITIAL_SUPPORT_USERNAME=alfred
INITIAL_SUPPORT_PASSWORD=change-me

# Redis / Broker
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_NAME=fila_pedidos
REDIS_BLOCK_TIMEOUT=5
CATALOG_CONSUMER_BLOCK_TIMEOUT=0

# Service URLs
CATALOG_SERVICE_URL=http://catalog:8000/items
CATALOG_REQUEST_TIMEOUT=3.0

# SQLite databases
AUTH_DB_FILE=auth.db
CATALOG_DB_FILE=catalog.db
ORDERS_DB_FILE=orders.db
PAYMENTS_DB_FILE=payments.db
NOTIFICATIONS_DB_FILE=notifications.db
